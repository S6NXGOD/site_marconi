// Prisma schema — Grupo Dr. Marconi Nunes
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // "native" = máquina de desenvolvimento.
  // Os alvos Debian são obrigatórios no Railway: sem eles o Prisma Client
  // não encontra o engine no container e o app quebra em produção.
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(EDITOR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  excerpt     String? // resumo exibido nos cards
  content     String
  coverImage  String? // caminho local (/foto.jpg) ou URL https
  author      String? // ex.: "Redação Grupo Marconi Nunes"
  category    NewsCategory @default(GERAL)
  isPublished Boolean      @default(false)
  /// Link da matéria original, quando a notícia veio de uma fonte externa.
  /// É único: é ele que impede a mesma matéria de ser importada duas vezes.
  sourceUrl   String?      @unique
  /// Nome da fonte para o crédito (ex.: "TCE-PI").
  sourceName  String?
  /// Data editorial — é esta que o site exibe e ordena. Sai da data do dia,
  /// mas pode ser ajustada no painel (matéria sobre um fato de ontem).
  publishedAt DateTime     @default(now())
  /// Quando a linha foi criada. Não muda e não aparece no site: é o registro
  /// de quando a notícia entrou de fato, mesmo que a data editorial seja outra.
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  /// Tags livres (IRPF 2026, Impostos…). Complementam a vertente (category),
  /// não a substituem: category diz o SETOR; a tag diz o ASSUNTO.
  tags        Tag[]

  @@index([isPublished, publishedAt])
  @@index([category])
}

/// Assunto livre de uma notícia — reaproveitável entre várias (m2m).
/// O slug é a chave de reúso: "IRPF 2026" e "irpf 2026" viram a mesma tag.
model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  news News[]

  @@index([slug])
}

// Distingue a frente do assunto da notícia para filtragem no front-end.
enum NewsCategory {
  PUBLICO
  PRIVADO
  GERAL
}

// Alertas e prazos (ex.: "Prazo de Prestação de Contas TCE-PI")
// exibidos no portal para prefeituras e clientes corporativos.
model Alert {
  id          String        @id @default(cuid())
  title       String
  date        DateTime // data limite
  category    AlertCategory
  description String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now()) @updatedAt

  @@index([isActive, date])
  @@index([category])
}

enum AlertCategory {
  PUBLICO
  PRIVADO
}

// Prova social da CONPLAN: reels de "Contas Aprovadas" dos municípios.
// O vídeo entra pelo painel como EMBED (link do reel do Instagram).
model Approval {
  id           String   @id @default(cuid())
  municipality String // ex.: "Tanque do Piauí"
  label        String   @default("Contas Aprovadas") // selo exibido no card
  embedUrl     String? // link do reel — o card É a publicação incorporada
  isActive     Boolean  @default(true)
  order        Int      @default(0) // menor aparece primeiro
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([isActive, order])
}

// Contatos recebidos pelo formulário "Fale com o Comercial" (/comercial)
model CommercialLead {
  id        String     @id @default(cuid())
  name      String // Nome
  company   String // Empresa
  phone     String // Telefone
  need      String // Necessidade
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())

  @@index([createdAt])
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

// Opções do float de WhatsApp (ex.: "Já sou cliente", "Quero ser cliente").
model WhatsappContact {
  id        String   @id @default(cuid())
  title     String // "Já sou cliente"
  subtitle  String // "Contato administrativo"
  phone     String // só dígitos, com DDI: 5586999999999
  message   String // mensagem já preenchida no WhatsApp
  icon      String   @default("user") // chave do ícone (ver src/lib/icons.ts)
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([isActive, order])
}

// Seção "Duas vertentes, uma excelência" — cada aba é uma vertente.
model BusinessArea {
  id          String   @id @default(cuid())
  tabLabel    String // "MARCONI NUNES — SETOR PRIVADO"
  eyebrow     String // "Marconi Nunes Contabilidade"
  headline    String // "Solidez contábil para o setor privado"
  description String
  image       String? // foto 4:3 (upload no painel)
  imageAlt    String   @default("")
  // Cor de destaque da aba: "marconi" (dourado) ou "conplan" (azul).
  // Serve para o visitante perceber que trocou de vertente.
  accent      String   @default("marconi")
  ctaLabel    String   @default("Fale conosco")
  ctaHref     String   @default("#contato")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  services BusinessAreaService[]

  @@index([isActive, order])
}

model BusinessAreaService {
  id     String @id @default(cuid())
  areaId String
  name   String // "Área Fiscal e Tributária"
  icon   String @default("chart") // chave do ícone
  order  Int    @default(0)

  area BusinessArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([areaId, order])
}


/// Fonte de raspagem: uma página de listagem de notícias e os seletores CSS
/// que dizem onde estão os dados nela. Fica no banco, e não no código, para
/// um site mudar de layout sem exigir deploy.
model ScrapeSource {
  id       String       @id @default(cuid())
  name     String       /// ex.: "TCE-PI — Notícias"
  url      String       /// página de listagem
  category NewsCategory @default(PUBLICO) /// categoria das notícias importadas
  isActive Boolean      @default(true)

  // ——— Seletores da LISTAGEM ———
  /// Container de cada notícia. Os demais seletores são buscados dentro dele.
  itemSelector    String
  titleSelector   String?
  /// De onde sai o href. Vazio, procura o primeiro <a> do container.
  linkSelector    String?
  dateSelector    String?
  imageSelector   String?
  excerptSelector String?

  /// Categoria/assunto na listagem (ex.: "Serviços" na Receita). Vira uma tag
  /// sugerida na notícia importada.
  categorySelector String?

  // ——— Seletor da PÁGINA DA MATÉRIA ———
  /// Corpo do texto. Sem ele, o rascunho nasce só com o resumo da listagem.
  contentSelector String?

  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  @@index([isActive])
}

/// Marcadores de coisas que devem acontecer UMA vez na vida do banco.
///
/// Existe por causa de um caso concreto: o bootstrap de conteúdo perguntava
/// "a tabela está vazia?" para decidir se criava os padrões. Só que uma tabela
/// vazia também é o resultado de o admin ter apagado tudo de propósito — e o
/// deploy seguinte ressuscitava o conteúdo, com números de exemplo e tudo.
/// "Já rodou?" é a pergunta certa; "está vazio?" não é.
model SystemFlag {
  key       String   @id
  createdAt DateTime @default(now())
}
