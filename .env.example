# ──────────────────────────────────────────────────────────────
#  Grupo Dr. Marconi Nunes — variáveis de ambiente
#  Copie para .env (local) ou configure em Variables no Railway.
#  O arquivo .env NUNCA vai para o Git.
# ──────────────────────────────────────────────────────────────

# ─── Banco de dados (obrigatório) ───
# Railway: use a referência do Postgres -> ${{ Postgres.DATABASE_URL }}
# Local: se a senha tiver "@", codifique como %40 (ex.: Admin@123 -> Admin%40123)
DATABASE_URL="postgresql://postgres:senha@localhost:5432/marconinunes?schema=public"

# ─── Autenticação do painel (obrigatório) ───
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""
# URL pública COMPLETA do site. Sem isso o login falha em produção.
# Railway: https://SEU-APP.up.railway.app  (ou o domínio próprio)
NEXTAUTH_URL="http://localhost:3000"

# ─── Administrador inicial ───
# Criado automaticamente no primeiro start, apenas se não existir usuário.
# Trocar a senha depois em /admin/conta (aqui não muda mais nada).
ADMIN_EMAIL="admin@marconinunes.com.br"
ADMIN_PASSWORD=""
ADMIN_NAME="Administrador"

# ─── Uploads (produção) ───
# Pasta persistente das imagens do painel.
# No Railway, crie um Volume e aponte o mount path para /app/uploads.
# Se o volume estiver montado, RAILWAY_VOLUME_MOUNT_PATH já é usado sozinho
# e esta variável é opcional.
# UPLOAD_DIR="/app/uploads"

# ─── Opcionais ───
# Domínio próprio (se diferente do NEXTAUTH_URL) — usado em SEO/sitemap.
# NEXT_PUBLIC_SITE_URL="https://grupomarconinunes.com.br"

# Defina "false" para bloquear indexação mesmo em produção (ex.: homologação).
# ALLOW_INDEXING="true"

# Índice de aprovações no TCE-PI exibido em "Resultados" (só o número).
# Fica OCULTO enquanto não for definido: é uma afirmação factual sobre o
# Tribunal de Contas e não deve ir ao ar sem o dado real.
# NEXT_PUBLIC_STAT_TCE="98"
